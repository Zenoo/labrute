{
  "name": "labrute",
  "version": "2.97.12",
  "private": true,
  "type": "module",
  "engines": {
    "npm": ">=8.1.2",
    "node": ">=18.18.0"
  },
  "scripts": {
    "clean": "rimraf --glob \"client/build\" \"core/lib\" \"server/lib\" \"**/node_modules\" \"**/tsconfig.tsbuildinfo\"",
    "compile": "tsc -b tsconfig.build.json",
    "front": "pnpm --filter client start",
    "back": "pnpm --filter server start:watch",
    "eternaltwin": "eternaltwin",
    "eternaltwin:start": "eternaltwin start",
    "start": "pnpm --filter server start",
    "dev": "concurrently --prefix \"[{name}]\" --names \"DB,SERVER,CLIENT,ETWIN\" -c \"bgMagenta.bold,bgBlue.bold,bgGreen.bold,bgYellow.bold\" \"pnpm studio\" \"pnpm back\" \"pnpm front\" \"pnpm eternaltwin:start\"",
    "dev:preview": "pnpm --filter client build && concurrently --prefix \"[{name}]\" --names \"DB,SERVER,CLIENT,ETWIN\" -c \"bgMagenta.bold,bgBlue.bold,bgGreen.bold,bgYellow.bold\" \"pnpm studio\" \"pnpm back\" \"pnpm --filter client preview\" \"pnpm eternaltwin:start\"",
    "front:preview": "pnpm --filter client build && pnpm --filter client exec vite preview --port 3000",
    "build": "pnpm compile && pnpm build:client",
    "build:client": "pnpm --filter client build",
    "db:migrate:manual": "pnpm --filter server db:migrate:manual",
    "db:sync:dev": "pnpm --filter server db:sync:dev",
    "db:sync:prod": "pnpm --filter server db:sync:prod",
    "db:resolve:applied": "pnpm --filter server db:resolve:applied",
    "db:resolve:rolled-back": "pnpm --filter server db:resolve:rolled-back",
    "db:seed": "pnpm --filter server db:seed",
    "db:reset": "pnpm --filter server db:reset",
    "studio": "pnpm --filter server studio",
    "add:client": "pnpm --filter client add",
    "add:server": "pnpm --filter server add",
    "add:core": "pnpm --filter core add",
    "sfx:wsl:generate": "cd ./client/public/sfx && audiosprite $(find . -type f -name '*.mp3' -o -name '*.wav') -o sfx -u . && mv ./sfx.json ./../../src/assets/",
    "sfx:generate": "cd ./client/public/sfx && audiosprite -o sfx -e mp3 -u . $(ls **/*.mp3 **/*.wav | grep -v 'background.mp3' | grep -v 'unused/'  | grep -v 'sfx.mp3' ) && mv ./sfx.json ./../../src/assets/",
    "remove:client": "pnpm --filter client remove",
    "remove:server": "pnpm --filter server remove",
    "remove:core": "pnpm --filter core remove",
    "run:retrieveFirstBonus": "pnpm --filter server run:retrieveFirstBonus",
    "run:fixErroredBonuses": "pnpm --filter server run:fixErroredBonuses",
    "sitemap:generate": "pnx ts-node ./scripts/generateSitemap.ts",
    "core:export": "pnx ts-node ./scripts/generateCoreExports.ts",
    "skills:generate": "pnx ts-node ./scripts/generateSkillComponents.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@eternaltwin/cli": "^0.16.0",
    "@types/node": "^18.11.15",
    "audiosprite": "^0.7.2",
    "concurrently": "^7.6.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.10.0",
  "dependencies": {
    "@typescript-eslint/parser": "^8.59.3"
  }
}
